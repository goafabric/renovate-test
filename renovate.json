{
  "baseBranches": [
    "refactoring"
  ],
  "enabledManagers": ["gradle","docker-compose","github-actions"],
  "extends": [
    "github>goafabric/renovate-bot"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "branch",
      "groupName": "all-updates"
    }
  ]
}